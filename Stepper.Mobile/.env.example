# Environment variables for Stepper Mobile
#
# For local development: copy this file to .env and fill in the values.
# The .env file is read by app.config.ts via process.env at build time.
#
# For EAS builds: set these as EAS secrets:
#   eas secret:create --name SUPABASE_URL --value "..."
#   eas secret:create --name SUPABASE_ANON_KEY --value "..."
#   etc.

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# API Configuration
# The base URL of the .NET backend API server.
# Note: The /api/v1 path is added automatically by the HTTP client.
API_BASE_URL=http://localhost:5000

# Google OAuth Configuration (Browser-based flow)
# Get this from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# PostHog Analytics
POSTHOG_API_KEY=your-posthog-api-key
POSTHOG_HOST=https://eu.i.posthog.com
